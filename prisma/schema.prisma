// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Assessment {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  postcode        String
  ageGroup        String
  gender          String?
  
  // This connects many Answers to one Assessment
  answers         Answer[]
  
  totalScore      Int
  riskLevel       String
}

model Question {
  id           String   @id @default(cuid())
  text         String   // e.g., "Are you over 65?"
  slug         String   @unique // e.g., "is-over-65"
  category     String   // e.g., "Risk Profile"
  isActive     Boolean  @default(true) // Allows you to "remove" questions without deleting data
  weight       Int      @default(1)    // Use this for calculating scores
  options      Option[]  // Connects multiple options (buttons) to one question
  answers      Answer[]
}
model Option {
  id           String   @id @default(cuid())
  label        String   // e.g., "Yes"
  icon         String   // e.g., "🏠" or "ShieldCheck"
  score        Int      // The points this specific button is worth
  questionId   String
  question     Question @relation(fields: [questionId], references: [id])
}
model Answer {
  id            String     @id @default(cuid())
  assessmentId  String
  questionId    String
  value         String     // Store response as a string or JSON to handle booleans/text
  
  assessment    Assessment @relation(fields: [assessmentId], references: [id])
  question      Question   @relation(fields: [questionId], references: [id])
}