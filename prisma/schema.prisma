// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Assessment {
  id              String   @id @default(cuid())
  fingerprint     String   @unique
  createdAt       DateTime @default(now())
  postcode        String
  ageGroup        String
  gender          String?
  
  // This connects many Answers to one Assessment
  answers         Answer[]
  
  totalScore      Int
  riskLevel       String
}

model Question {
  id        String   @id @default(cuid())
  order     Int
  indexType String   @default("NONE")
  text      String   
  slug      String   @unique 
  category  String   
  type      String   @default("RADIO") // NEW: "RADIO", "CHECKBOX", "TEXT", "NUMBER"
  isFollowup Boolean  @default(false)
  isActive  Boolean  @default(true)
  weight    Int      @default(1)
  options   Option[]
  answers   Answer[]
}
model Option {
  id           String   @id @default(cuid())
  slug         String
  label        String   // e.g., "Yes"
  icon         String   // e.g., "🏠" or "ShieldCheck"
  score        Float      // The points this specific button is worth
  questionId   String
  followup     String[] // Array of slugs for follow-up questions
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    Answer[]
}
model Answer {
  id           String     @id @default(cuid())
  assessmentId String
  questionId   String
  
  // Handles plain text, numbers, or serialized selections natively
  value        Json       
  
  // Connects the answer directly to the structured options picked (if applicable)
  selectedOptions Option[] 

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
}